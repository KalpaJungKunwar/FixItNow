{
  "kind": "collectionType",
  "collectionName": "bids",
  "info": {
    "singularName": "bid",
    "pluralName": "bids",
    "displayName": "Bid"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "amount": {
      "type": "decimal",
      "required": true
    },
    "message": {
      "type": "text",
      "required": true
    },
    "availability": {
      "type": "string",
      "required": true
    },
    "bid_status": {
      "type": "enumeration",
      "required": true,
      "default": "pending",
      "enum": [
        "pending",
        "accepted",
        "rejected"
      ]
    },
    "service_request": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::service-request.service-request"
    },
    "provider": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "service_requests",
  "info": {
    "singularName": "service-request",
    "pluralName": "service-requests",
    "displayName": "Service Request"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "plumbing",
        "electrical",
        "carpentry",
        "cleaning",
        "technical",
        "painting",
        "other"
      ]
    },
    "location": {
      "type": "string",
      "required": true
    },
    "preferred_date": {
      "type": "datetime",
      "required": true
    },
    "suggested_budget": {
      "type": "biginteger",
      "required": true
    },
    "service_status": {
      "type": "enumeration",
      "required": true,
      "default": "pending",
      "enum": [
        "pending",
        "in_progress",
        "awaiting_confirmation",
        "completed",
        "cancelled"
      ]
    },
    "customer": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "bids": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::bid.bid"
    },
    "provider_lat": {
      "type": "decimal"
    },
    "provider_lng": {
      "type": "float"
    },
    "customer_lat": {
      "type": "decimal"
    },
    "customer_lng": {
      "type": "decimal"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "service_request"
    }
  }
}
